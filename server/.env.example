# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Port the proxy listens on
PORT=8787

# Origin allowed to call this proxy (the Vite dev server by default).
# In production (e.g. Vercel), set this to your deployed domain, e.g.
# https://your-app.vercel.app — client and API share one domain there, so
# this mainly guards against other sites calling the endpoint directly.
CLIENT_ORIGIN=http://localhost:5173

# Soft daily cap enforced locally, kept under Groq's free-tier 2000 req/day
# to leave headroom for other usage on the same key. Resets at UTC midnight
# and is held in memory only (resets on server restart — see README).
DAILY_QUOTA_LIMIT=1800

# Supabase project URL and SERVICE ROLE key (not the anon key) — used
# server-side only to verify user session JWTs and to read/write per-user
# data with RLS bypassed. Get both from Project Settings > API in Supabase.
# Never expose the service role key to the client.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google Cloud OAuth client (same one configured as the Google provider in
# Supabase Auth) — used server-side to mint access tokens from the stored
# refresh token when calling Calendar APIs. Get from console.cloud.google.com
# > APIs & Services > Credentials.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# 32-byte key (base64) used to encrypt stored Google refresh tokens at rest.
# Generate with: openssl rand -base64 32
GOOGLE_TOKEN_ENC_KEY=
